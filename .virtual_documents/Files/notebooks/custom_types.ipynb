class Ed:
    def __init__(self, x, y):
        if type(x) == int:
            self.x = F_p(x)
        elif type(x) == F_p:
            self.x = x
        else:
            raise TypeError("Arguments of Ed should be ints or F_p")

        if type(y) == int:
            self.y = F_p(y)
        elif type(y) == F_p:
            self.y = y
        else:
            raise TypeError("Arguments of Ed should be ints or F_p")

        if not Ed.eq(self.x, self.y) == F_p(0):
            raise ValueError("The supplied x,y pair does not satisfy equation `Eq`.")

    def __eq__(self, other):
        if type(self) == type(other):
            if self.x == other.x and self.y == other.y:
                return True

    def __ne__(self, other):
        return not self.__eq__(self, other)

    def __repr__(self):
        return f"{type(self).__name__}(\n    .x = {self.x} \n    .y = {self.y}\n)"

    @staticmethod
    def eq(x: F_p, y: F_p) -> F_p:
        """The function defined on F_p x F_p that defines the elliptic curve
        used by Ed25519.
        """
        return y**2 - x**2 - d * x**2 * y**2 - 1

    @classmethod
    def add_operator(cls, M, N):
        if not isinstance(M, Ed):
            raise ValueError("A curve point can only be added to another curve point.")
        if not isinstance(N, Ed):
            raise ValueError("A curve point can only be added to another curve point.")
        else:
            x = (M.x * N.y + N.x * M.y) * (1 + d * M.x * N.x * M.y * N.y).mod_inv()
            y = (M.y * N.y + M.x * N.x) * (1 - d * M.x * N.x * M.y * N.y).mod_inv()
        return cls(x, y)

    def __add__(self, N):
        return self.add_operator(self, N)

    def to_quad(self):
        """extended homogeneous coordinates"""
        return Quad(self.x, self.y, F_p(1), self.x * self.y)


