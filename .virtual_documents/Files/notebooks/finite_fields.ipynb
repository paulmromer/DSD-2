    @staticmethod
    def mod_sqrt(class_obj):
        def _mod_sqrt(self):
            """This calculation of the sqrt applies only for
            the case where the modulus satisfies mod % 8 = 5.
            This is true for both p and ell.
            """
            if not self.mod % 8 == 5:
                raise ValueError("Modulus needs to satisfy p % 8 = 5.")
            m_test = class_obj(
                pow(
                    self.value,
                    ((self.mod + 3) * class_obj(8).mod_inv()).value,
                    self.mod,
                ),
                self.mod,
            )
            if m_test * m_test == self.value:
                return m_test
            elif (self.sqrt_minus_1 * m_test) * (
                self.sqrt_minus_1 * m_test
            ) == self.value:
                return class_obj((self.sqrt_minus_1 * m_test).value, self.mod)
            else:
                return None

        return _mod_sqrt








