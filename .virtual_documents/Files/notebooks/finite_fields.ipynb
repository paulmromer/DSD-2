class Prop:
    """A property class that makes attributes immutable."""

    def __init__(self, attr):
        self._attr = attr

    def get(self, obj):
        return getattr(obj, self._attr)

    def set(self, obj, value):
        print("You cannot modify this attribute")
        return

    def delete(self, obj):
        print("You cannot delete this attribute")
        return








class FF(type):
    def __new__(mcs, name, bases, class_dct):
        """Creates a new object, class_obj, by invoking __new__
        on the parent, `type`.
        """
        # print("Running __new__")
        class_obj = super().__new__(mcs, name, bases, class_dct)

        # create properties
        FF.define_property(class_obj)

        # specify init and repr
        setattr(class_obj, "__init__", FF.init(class_obj))
        setattr(class_obj, "__repr__", FF.repr(class_obj))

        # specify other methods
        setattr(class_obj, "__add__", FF.add(class_obj))
        setattr(class_obj, "__radd__", FF.radd(class_obj))
        setattr(class_obj, "__neg__", FF.neg(class_obj))
        setattr(class_obj, "__sub__", FF.sub(class_obj))
        setattr(class_obj, "__rsub__", FF.rsub(class_obj))
        setattr(class_obj, "__mul__", FF.mul(class_obj))
        setattr(class_obj, "__rmul__", FF.rmul(class_obj))
        setattr(class_obj, "__pow__", FF.pow(class_obj))
        setattr(class_obj, "__truediv__", FF.truediv(class_obj))
        setattr(class_obj, "__lt__", FF.lt(class_obj))
        setattr(class_obj, "__gt__", FF.gt(class_obj))
        setattr(class_obj, "__eq__", FF.eq(class_obj))
        setattr(class_obj, "__int__", FF.int(class_obj))
        setattr(class_obj, "mod_inv", FF.mod_inv(class_obj))
        setattr(class_obj, "mod_sqrt", FF.mod_sqrt(class_obj))

        return class_obj

    def __init__(cls, clsname, bases, namespace):
        # print("Initializing:", clsname, bases, namespace) 
        _modulus = int(cls.modulus)
        cls.sqrt_minus_1 = cls(
            pow(
                2, 
                (_modulus - 1) * pow(4, _modulus - 2, _modulus) % _modulus,
                _modulus
            )
        )
        super().__init__(clsname, bases, namespace)
    
    @staticmethod
    def init(class_obj):
        def _init(self, *obj_args, **obj_kwargs):
            if obj_kwargs:
                for prop in class_obj.props:
                    attr = f"_{prop}"
                    if prop in obj_kwargs.keys():
                        arg = obj_kwargs[prop]
                        setattr(self, attr, arg)

            if obj_args:
                for prop, arg in zip(class_obj.props, obj_args):
                    attr = f"_{prop}"
                    setattr(self, attr, arg)

            attr = "_mod"
            if type(self.modulus) == int:
                setattr(self, attr, self.modulus)
            else:
                setattr(self, attr, self.modulus.value)

            attr = "_value"
            setattr(self, attr, self.input % self.mod)

        return _init

    @staticmethod
    def repr(class_obj):
        """Have to be careful about how to collect the 
        information needed for the repr.
        """
        def _repr(self):
            value_str = str(getattr(self, "value"))
            return f"{class_obj.__name__}({value_str})"
        return _repr

    @staticmethod
    def define_property(class_obj):
        """If it would be helpful, it would be possible to specify
        other properties but if so, the logic of the init function
        would have to be changed. Now it tests only for 'input'.
        """
        class_obj.props = ["input", "mod", "value"]
        for prop in class_obj.props:
            attr = f"_{prop}"
            prop_obj = property(
                fget=Prop(attr).get, fset=Prop(attr).set, fdel=Prop(attr).delete
            )
            setattr(class_obj, prop, prop_obj)
        return class_obj

    @staticmethod
    def add(class_obj):
        def _add(self, other):
            if type(self) == type(other):
                return class_obj(self.value + other.value, self._mod)
            elif type(other) == int:
                return class_obj(self.value + other, self._mod)
            else:
                raise TypeError("Can only add same type or int.")

        return _add

    @staticmethod
    def radd(class_obj):
        def _radd(self, other):
            if type(self) == type(other):
                return class_obj(other.value + self.value, self._mod)
            elif type(other) == int:
                return class_obj(self.value + other, self._mod)
            else:
                raise TypeError("Can only add same type or int.")

        return _radd

    @staticmethod
    def neg(class_obj):
        def _neg(self):
            return class_obj((0 - self.value), self._mod)

        return _neg

    @staticmethod
    def sub(class_obj):
        def _sub(self, other):
            if type(other) == type(self):
                if self._mod == other._mod:
                    return class_obj(self.value - other.value, self._mod)
                else:
                    raise TypeError("Can only add same type or int.")
            elif type(other) == int:
                return class_obj(self.value - other, self._mod)
            else:
                raise TypeError("From type only subtract same type or int.")

        return _sub

    @staticmethod
    def rsub(class_obj):
        def _rsub(self, other):
            if type(other) == type(self):
                if self._mod == other._mod:
                    return class_obj(other.value - self.value, self._mod)
                else:
                    raise TypeError("Can only add same type or int.")
            elif type(other) == int:
                return class_obj(other - self.value, self._mod)
            else:
                raise TypeError("Can only subtract from same type or int.")

        return _rsub

    @staticmethod
    def mul(class_obj):
        def _mul(self, other):
            if type(other) == type(self):
                if self._mod == other._mod:
                    return class_obj(self.value * other.value, self._mod)
                else:
                    raise TypeError("Can only multiply by same type or int.")
            elif type(other) == int:
                return class_obj(self.value * other, self._mod)
            else:
                raise TypeError("Can only only multiply by same type or int.")

        return _mul

    @staticmethod
    def rmul(class_obj):
        def _rmul(self, other):
            if type(other) == type(self):
                if self._mod == other._mod:
                    return class_obj(other.value * self.value, self._mod)
                else:
                    raise TypeError("Can only multiply by same type or int.")
            elif type(other) == int:
                return class_obj(other * self.value, self._mod)
            else:
                raise TypeError("Can only only multiply by same type or int.")

        return _rmul

    @staticmethod
    def truediv(class_obj):
        def _truediv(self, other):
            if type(other) == type(self):
                if self.mod == other.mod:
                    return self.__mul__(other.mod_inv())

        return _truediv

    @staticmethod
    def pow(class_obj):
        def _pow(self, other, mod=None):
            if type(other) == int:
                if not mod:
                    return (self.value**other) % self.mod
                else:
                    return pow(self, other, mod)

        return _pow

    @staticmethod
    def lt(class_obj):
        def _lt(self, other):
            if type(other) == type(self):
                if self._mod == other._mod:
                    return self.value < other
                else:
                    raise TypeError("Can only compare w same type or int.")
            elif type(other) == int:
                return self.value < other
            else:
                raise TypeError("Can only compare w same type or int.")

        return _lt

    @staticmethod
    def gt(class_obj):
        def _gt(self, other):
            if type(other) == type(self):
                if self._mod == other._mod:
                    return self.value > other
                else:
                    raise TypeError("Can only compare w same type or int.")
            elif type(other) == int:
                return self.value > other
            else:
                raise TypeError("Can only compare w same type or int.")

        return _gt

    @staticmethod
    def eq(class_obj):
        def _eq(self, other):
            if type(self) == type(other):
                return self.value == other.value
            elif type(other) == int:
                return self.value == other
            else:
                return False

        return _eq

    @staticmethod
    def ne(class_obj):
        def _ne(self, other):
            if not self.__eq__(other):
                return True
            else:
                return False

        return _ne

    @staticmethod
    def int(class_obj):
        def _int(self):
            return self.value

        return _int
        
    @staticmethod
    def mod_inv(class_obj):
        def _mod_inv(self):
            return class_obj(pow(self.value, self.mod - 2, self.mod), self.mod)

        return _mod_inv

