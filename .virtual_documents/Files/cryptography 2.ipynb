def bin_rep(m):
    z = m
    bin_bit = {}
    for j in range(255, -1, -1): 
        bin_bit[j], z  = divmod(z, 2**j)
    return bin_bit

def value_from(br):
    s = 0
    for k, v in br.items():
        s += 2**k * v 
    return s 


class CurvePoint2:
    def __init__(self, x, y):
        self.x = x % r
        self.y = y % r

    def __eq__(self, N):
        if all([
                isinstance(N, CurvePoint), 
                self.x == N.x,
                self.y
            ]):
            return True 
        else: 
            return False

    def two_to_power_j_times_(self): 
        mult_of_ = {}
        mult_of_[0] = self
        for j in range(1, 255):
            mult_of_[j] = cp_add( mult_of_[j-1], mult_of_[j-1] )
        return mult_of_
    
    def scalar_mult_(self, m):
        m = m % r
        dict = self.two_to_power_j_times_()
        cp = CurvePoint(0,1)
        for j in range(255):
            if bin_rep(m)[j]: 
                cp = cp_add(dict[j], cp)
        return cp
        
    def __rmatmul__(self, m):
        return self.scalar_mult_(m)

    


G = CurvePoint2(G_x, G_y)

