class Quad:
    """Points in F_p^4 that facilitate addition of curve points
    and scalar multiplication of curve points.

    For a point
        R = (R.x, R.y) in F_p x F_p,
    there is a continum of points
        Q =  (Q.X, Q.Y, Q.Z, Q.T),
    indexed by Q.Z, where
        Q.X = R.x * Q.Z
        Q.Y = R.y * Q.Z
        Q.T = R.x * R.y * Q.Z
    """

    def __init__(self, X, Y, Z, T):
        self.X = X
        self.Y = Y
        self.Z = Z
        self.T = T

    def __repr__(self):
        return f"""{type(self).__name__}(    
        X = {self.X},
        Y = {self.Y},
        Z = {self.Z},
        T = {self.T}
    )"""

    def to_point(self):
        # if not type(self.Z) == int:
        #     print("self.Z is not an int")
        Z_inv = self.Z.mod_inv()
        return Ed((self.X * Z_inv).value, (self.Y * Z_inv).value)

    @classmethod
    def from_point(cls, R):
        return cls(R.x, R.y, F_p(1), R.x * R.y)

    def point_add_quad(self, Q):
        """Addition formula in extended coordinates.

        With repeated application, the value for M.Z is allowed
        adjust freely. This avoids repeated application of the
        expensive F_p(M.Z).mod_inv() calculation required to normalize
        the coordinates.

        The alphabetic naming convention followed for the different
        terms in this calculation is a direct translation of the
        convention used in IETF RFC 8032.
        """
        if not isinstance(Q, Quad):
            raise ValueError("The supplied value must be a Quad.")
        alpha, bravo = (self.Y - self.X) * (Q.Y - Q.X), (self.Y + self.X) * (Q.Y + Q.X)
        charlie, delta = 2 * self.T * Q.T * d, 2 * self.Z * Q.Z
        echo, foxtrot, gulf, hotel = (
            bravo - alpha,
            delta - charlie,
            delta + charlie,
            bravo + alpha,
        )
        return Quad(
            (echo * foxtrot),
            (gulf * hotel),
            (foxtrot * gulf),
            (echo * hotel),
        )








class F_l(metaclass=FF):
    modulus = int(ell.value)

    def scalar_mult(self, R: Ed):
        """Takes as input a scalar m from F_l and a CurvePoint R
        and returns the point representation of the scalar of product
        m times R.

        To calculate the scalar product, the function creates a
        dictionary with keys that are integers in range(0, 256)
        and values that are quads. For a key k, dict[k] is equal
        to 2**k times the quad representation of R.
        """
        if not isinstance(R, Ed):
            raise ValueError("Scalar multiplication is only defined for curve points.")
        bi = BitList.from_int(self.value)
        Q = Quad.from_point(R)
        pow2_x_R = {}
        pow2_x_R[0] = Q
        pow2_x_R[1] = Q.point_add_quad(Q)
        for j in range(2, 256):
            pow2_x_R[j] = pow2_x_R[j - 1].point_add_quad(pow2_x_R[j - 1])

        K = [pow2_x_R[k] for k, j in enumerate(bi) if j]
        sum = Ed(0, 1).to_quad()
        for elem in K:
            sum = sum.point_add_quad(elem)
        return sum.to_point()

    def __matmul__(self, R: Ed):
        return self.scalar_mult(R)








