from random import randint

p = 2**255 - 19

z = randint(0, p-1)

x = 9 * z % p
x














def r(n, h):
    print(f"9 to the power 2**{n} is:")
    print(f"{h * h % p}")
    return 2 * n, h * h


r(1, 9)


r(2, 81)


_j, _v = r(4, 6561)


_j, _v = r(_j, _v)


_j, _v = (1, 9)
for j in range(9):
    _j, _v = r(_j, _v % p)









