def sub_61(g):
    return {(n * g) % 61 for n in range(62)}


def sub_63(g):
    return {(n * g) % 63 for n in range(63)}


for i in range(63):
    print(sub_63(i))


def sub_64(g):
    return {(n * g) % 64 for n in range(64)}


def subgroups_61():
    subgroups = set()
    for m in range(61):
        subgroups.add(frozenset(sub_61(m)))
    return subgroups


for subg in subgroups_61():
    print(subg)


