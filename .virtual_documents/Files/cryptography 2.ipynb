def cp_add(M, N):
    x = ( (M.x * N.y + N.x * M.y) * inv((1 + d * M.x * N.x * M.y * N.y), r) ) % r
    y = ( (M.y * N.y + M.x * N.x) * inv((1 - d * M.x * N.x * M.y * N.y), r) ) % r
    return CurvePoint(x,y)     


